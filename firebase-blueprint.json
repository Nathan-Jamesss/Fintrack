{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "monthlyBudget": { "type": "number", "description": "User's monthly budget" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email", "displayName", "monthlyBudget", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Transaction ID" },
        "uid": { "type": "string", "description": "User ID who owns the transaction" },
        "type": { "type": "string", "enum": ["income", "expense"], "description": "Transaction type" },
        "category": { "type": "string", "description": "Transaction category" },
        "amount": { "type": "number", "description": "Transaction amount" },
        "description": { "type": "string", "description": "Transaction description" },
        "date": { "type": "string", "format": "date", "description": "Transaction date" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["id", "uid", "type", "category", "amount", "description", "date", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Transaction documents"
    }
  }
}
